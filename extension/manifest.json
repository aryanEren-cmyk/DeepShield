{
  "manifest_version": 3,
  "name": "DeepShield - Deepfake Detector",
  "version": "1.0",
  "description": "Right-click any image to scan it for deepfakes",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}